# Shared default analysis parameters.
# User-provided shell env vars always win over these defaults.

# Channel selection
# MAIN_UP_CH=17
DUAL_PROBE_MIN_CHANNELS=24
ENABLE_SWR=1

# UP-state detection robustness
UP_SMOOTH_S=0.10
UP_TARGET_MIN_FRAC=0.20
UP_TARGET_MAX_FRAC=0.85
UP_K_HI_START=1.9
UP_K_LO_START=1.5
UP_MIN_GAP_S=0.005
UP_MERGE_GAP_S=0.05
UP_MIN_LEN_S=0.03
UP_MIN_PEAK_Z=3.2
UP_MIN_MEAN_Z=2.2
UP_MIN_P90_Z=2.8
UP_MIN_STRONG_FRAC=0.08
SPONT_POST_UP_REFRACTORY_S=0.10
UP_AUTO_RELAX_IF_EMPTY=1
UP_MIN_KEEP_COUNT_FOR_RELAX=120
UP_RELAX_MIN_LEN_S=0.03
UP_RELAX_STRONG_FRAC=0.05
UP_MIN_FRAC=0.002
UP_REQUIRE_Z_SHAPE_FILTER=0
UP_MIN_DUR_POST_S=0.03
UP_MIN_DUR_POST_FLOOR_S=0.00

# Robust z-normalization
UP_X_LO_Q=0.01
UP_X_HI_Q=0.99
UP_Z_STD_FLOOR=1e-3
UP_Z_ABS_CAP=25.0
